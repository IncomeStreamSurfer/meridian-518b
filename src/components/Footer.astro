---
import EmailCapture from './EmailCapture.astro';
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
const isDark = variant === 'dark';
const ring = isDark ? 'border-white/10' : 'border-ink/10';
const tint = isDark ? 'text-white/60' : 'text-muted';
const year = new Date().getFullYear();
---
<footer class={`relative z-10 border-t ${ring}`}>
  <div class="mx-auto max-w-7xl px-6 lg:px-10 py-16 grid gap-12 md:grid-cols-[1.2fr_1fr]">
    <div>
      <p class={`font-mono text-xs tracking-[0.25em] uppercase ${tint} mb-3`}>— N. 51.5074° / W. 0.1278°</p>
      <h3 class="font-display text-3xl md:text-4xl leading-tight max-w-lg">Be first through the door when Meridian opens.</h3>
      <p class={`mt-3 text-sm ${tint} max-w-md`}>Early access, a founders' letter, and the occasional dispatch from the farms we work with.</p>
      <div class="mt-6">
        <EmailCapture variant={variant} source="footer" id="footer-list" />
      </div>
    </div>
    <div class={`flex flex-col gap-6 text-sm ${tint}`}>
      <div>
        <p class="font-mono text-[10px] tracking-[0.25em] uppercase mb-3">Explore</p>
        <ul class="space-y-2">
          <li><a href="/" class="hover:text-ember">Home</a></li>
          <li><a href="/our-story" class="hover:text-ember">Our Story</a></li>
          <li><a href="/thanks" class="hover:text-ember">Confirmation</a></li>
        </ul>
      </div>
      <div>
        <p class="font-mono text-[10px] tracking-[0.25em] uppercase mb-3">Contact</p>
        <p>hello@meridian.coffee</p>
      </div>
    </div>
  </div>
  <div class={`border-t ${ring}`}>
    <div class={`mx-auto max-w-7xl px-6 lg:px-10 py-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-xs font-mono ${tint}`}>
      <p>© {year} Meridian Coffee Company. All rights reserved.</p>
      <p>Crafted slowly. Shipped with care.</p>
    </div>
  </div>
</footer>
